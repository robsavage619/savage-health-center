# Copy to .env and fill in values.
# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=data

# ── Database ──────────────────────────────────────────────────────────────────
# DB_ENCRYPTION_KEY is fetched from Keychain at boot; set via: shc auth set-db-key

# ── WHOOP OAuth ───────────────────────────────────────────────────────────────
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://127.0.0.1:8000/auth/whoop/callback

# ── Hevy ──────────────────────────────────────────────────────────────────────
# HEVY_API_KEY stored in Keychain (shc.hevy.access_token.v1)

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_DAILY_CAP_USD=2.00

# ── LLM mode: "auto" | "local_only" ──────────────────────────────────────────
SHC_LLM_MODE=auto

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.3:70b

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
